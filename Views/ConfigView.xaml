<UserControl x:Class="工业传感器实时监控上位机.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="Transparent">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="Tune" Width="24" Height="24"
                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                    VerticalAlignment="Center"/>
            <TextBlock Text=" 系统参数配置" FontSize="22" FontWeight="Bold" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 配置内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 全局参数 -->
                <Border Effect="{DynamicResource MaterialDesignShadowDepth1}"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Settings" Width="20" Height="20"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                    VerticalAlignment="Center"/>
                            <TextBlock Text=" 全局参数" FontSize="16" FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="采样间隔 (ms):" 
                                       VerticalAlignment="Center" Margin="0,0,12,12"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     Text="{Binding SampleIntervalMs}" 
                                     Margin="0,0,24,12" Width="140"
                                     HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="曲线缓存点数:" 
                                       VerticalAlignment="Center" Margin="0,0,12,12"/>
                            <TextBox Grid.Row="0" Grid.Column="3" 
                                     Text="{Binding MaxCachePoints}" 
                                     Width="140" Margin="0,0,0,12"
                                     HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 温湿度传感器配置 -->
                <Border Effect="{DynamicResource MaterialDesignShadowDepth1}"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,12"
                        BorderBrush="#42A5F5" BorderThickness="0,0,0,3">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="TemperatureCelsius" Width="20" Height="20"
                                                    Foreground="#42A5F5" VerticalAlignment="Center"/>
                            <TextBlock Text=" 温湿度传感器配置" FontSize="16" FontWeight="Bold" 
                                       Foreground="#42A5F5" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TempSensorConfig.Name}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="单位:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding TempSensorConfig.Unit}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="报警上限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TempSensorConfig.AlarmUpper}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="报警下限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TempSensorConfig.AlarmLower}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最小值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TempSensorConfig.MinValue}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="最大值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding TempSensorConfig.MaxValue}" Margin="0,0,0,10"/>

                            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                                      Content="启用该传感器" IsChecked="{Binding TempSensorConfig.Enabled}" 
                                      Margin="0,4,0,0"
                                      Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 压力传感器配置 -->
                <Border Effect="{DynamicResource MaterialDesignShadowDepth1}"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,12"
                        BorderBrush="#FFA726" BorderThickness="0,0,0,3">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Speedometer" Width="20" Height="20"
                                                    Foreground="#FFA726" VerticalAlignment="Center"/>
                            <TextBlock Text=" 压力传感器配置" FontSize="16" FontWeight="Bold" 
                                       Foreground="#FFA726" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PressureSensorConfig.Name}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="单位:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding PressureSensorConfig.Unit}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="报警上限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PressureSensorConfig.AlarmUpper}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="报警下限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding PressureSensorConfig.AlarmLower}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最小值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PressureSensorConfig.MinValue}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="最大值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding PressureSensorConfig.MaxValue}" Margin="0,0,0,10"/>

                            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                                      Content="启用该传感器" IsChecked="{Binding PressureSensorConfig.Enabled}" 
                                      Margin="0,4,0,0"
                                      Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 振动传感器配置 -->
                <Border Effect="{DynamicResource MaterialDesignShadowDepth1}"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,12"
                        BorderBrush="#AB47BC" BorderThickness="0,0,0,3">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Vibrate" Width="20" Height="20"
                                                    Foreground="#AB47BC" VerticalAlignment="Center"/>
                            <TextBlock Text=" 振动传感器配置" FontSize="16" FontWeight="Bold" 
                                       Foreground="#AB47BC" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding VibrationSensorConfig.Name}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="单位:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding VibrationSensorConfig.Unit}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="报警上限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VibrationSensorConfig.AlarmUpper}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="报警下限:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding VibrationSensorConfig.AlarmLower}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最小值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VibrationSensorConfig.MinValue}" Margin="0,0,24,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="最大值:" VerticalAlignment="Center" Margin="0,0,12,10"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding VibrationSensorConfig.MaxValue}" Margin="0,0,0,10"/>

                            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                                      Content="启用该传感器" IsChecked="{Binding VibrationSensorConfig.Enabled}" 
                                      Margin="0,4,0,0"
                                      Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,8">
            <Button Content="保存配置" Command="{Binding SaveCommand}" 
                    Style="{StaticResource SuccessButtonStyle}"
                    Margin="0,0,12,0"
                    materialDesign:ButtonProgressAssist.IsIndeterminate="False"/>
            <Button Content="加载配置" Command="{Binding LoadCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
